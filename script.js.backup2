            { src: 'assets/fotos/_P5A7148.jpg', alt: 'NicolÃ¡s Capetillo - Retrato ClÃ¡sico', title: 'Retrato ClÃ¡sico' },
            { src: 'assets/fotos/_P5A7152.jpg', alt: 'NicolÃ¡s Capetillo - Headshot Profesional', title: 'Headshot Profesional' },
