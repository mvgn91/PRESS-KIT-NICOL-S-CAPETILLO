// ===== SISTEMA DE TEMA OSCURO =====
function initThemeSystem() {
    const themeToggle = document.getElementById('themeToggle');
    const html = document.documentElement;
    
    // Obtener tema guardado o usar tema claro por defecto
    const savedTheme = localStorage.getItem('theme');
    
    // Aplicar tema inicial
    if (savedTheme) {
        html.setAttribute('data-theme', savedTheme);
    } else {
        html.setAttribute('data-theme', 'light');
    }
    
    // FunciÃ³n para cambiar tema
    function toggleTheme() {
        const currentTheme = html.getAttribute('data-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        
        console.log('Cambiando tema de', currentTheme, 'a', newTheme);
        
        html.setAttribute('data-theme', newTheme);
        localStorage.setItem('theme', newTheme);
        
        // AnimaciÃ³n suave del cambio
        document.body.style.transition = 'all 0.3s ease';
        setTimeout(() => {
            document.body.style.transition = '';
        }, 300);
        
        // Forzar repaint para asegurar que los cambios se apliquen
        document.body.offsetHeight;
    }
    
    // Event listener para el botÃ³n
    if (themeToggle) {
        themeToggle.addEventListener('click', toggleTheme);
        console.log('Event listener agregado al botÃ³n de tema');
    } else {
        console.error('No se encontrÃ³ el botÃ³n de tema');
    }
    
    // Verificar estado inicial
    console.log('Tema inicial:', html.getAttribute('data-theme'));
}

// Inicializar sistema de tema cuando el DOM estÃ© listo
