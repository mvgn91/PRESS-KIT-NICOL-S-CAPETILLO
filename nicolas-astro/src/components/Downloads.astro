---
import data from '../data/nicolas.json';
const { downloads, contact, physical, languages, personal, skills } = data;
---

<!-- ===== FICHA TÉCNICA ===== -->
<section class="fch section" id="ficha-tecnica">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-number">05</span>
      <h2 class="section-title">Ficha Técnica</h2>
    </div>

    <div class="fch-layout">
      <!-- Photo column -->
      <div class="fch-photo reveal-left">
        <div class="fch-photo-frame">
          <img src={personal.fichaPhoto} alt="Fotografía de casting" loading="lazy" />
          <div class="fch-photo-overlay" aria-hidden="true">
            <span class="fch-photo-badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              Casting
            </span>
            <div class="fch-photo-stats">
              <span>{physical.height}</span>
              <span>{physical.weight}</span>
              <span>{physical.eyes}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Data column -->
      <div class="fch-data reveal-right">
        <!-- Physical -->
        <div class="fch-card">
          <div class="fch-card-head">
            <span class="fch-card-tag">Datos Físicos</span>
            <span class="fch-card-meta">Casting ID</span>
          </div>
          <div class="fch-stats-grid">
            <div class="fch-stat-item">
              <span class="fch-stat-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="22"/><polyline points="7 7 12 2 17 7"/><polyline points="7 17 12 22 17 17"/></svg>
              </span>
              <span class="fch-stat-label">Estatura</span>
              <span class="fch-stat-value">{physical.height}</span>
            </div>
            <div class="fch-stat-item">
              <span class="fch-stat-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </span>
              <span class="fch-stat-label">Ojos</span>
              <span class="fch-stat-value">{physical.eyes}</span>
            </div>
            <div class="fch-stat-item">
              <span class="fch-stat-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10h-10V2z"/><path d="M12 12 22 12A10 10 0 0 0 12 2v10z"/></svg>
              </span>
              <span class="fch-stat-label">Peso</span>
              <span class="fch-stat-value">{physical.weight}</span>
            </div>
            <div class="fch-stat-item">
              <span class="fch-stat-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 14a3 3 0 0 1-6 0H5a3 3 0 0 1 3-3h8a3 3 0 0 1 1 5.83z"/><path d="M12 11V8"/><circle cx="12" cy="4" r="1"/></svg>
              </span>
              <span class="fch-stat-label">Cabello</span>
              <span class="fch-stat-value">{physical.hair}</span>
            </div>
          </div>
        </div>

        <!-- Profile & Languages -->
        <div class="fch-row">
          <div class="fch-card fch-card--half">
            <div class="fch-card-head">
              <span class="fch-card-tag">Perfil</span>
            </div>
            <div class="fch-meta-list">
              <div class="fch-meta-item">
                <span class="fch-meta-label">Nacionalidad</span>
                <span class="fch-meta-value">{physical.nationality}</span>
              </div>
              <div class="fch-meta-item">
                <span class="fch-meta-label">Edad</span>
                <span class="fch-meta-value">{physical.age}</span>
              </div>
              <div class="fch-meta-item">
                <span class="fch-meta-label">Base</span>
                <span class="fch-meta-value">Guadalajara, MX</span>
              </div>
            </div>
          </div>

          <div class="fch-card fch-card--half">
            <div class="fch-card-head">
              <span class="fch-card-tag">Idiomas</span>
            </div>
            <div class="fch-lang-list">
              {languages.map(l => (
                <div class="fch-lang-item">
                  <span class="fch-lang-name">{l.language}</span>
                  <span class="fch-lang-level">{l.level}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Skills -->
        <div class="fch-card">
          <div class="fch-card-head">
            <span class="fch-card-tag">Habilidades</span>
            <span class="fch-card-meta">Artes · Técnicas</span>
          </div>
          <div class="fch-skills">
            <div class="fch-skills-group">
              <span class="fch-skills-group-label">Artes y Música</span>
              <div class="fch-skills-tags">
                {skills.arts.map(s => <span class="fch-skill-tag">{s}</span>)}
              </div>
            </div>
            <div class="fch-skills-group">
              <span class="fch-skills-group-label">Físicas y Técnicas</span>
              <div class="fch-skills-tags">
                {skills.physical.map(s => <span class="fch-skill-tag">{s}</span>)}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== CONTACTO + DESCARGABLES ===== -->
<section class="cnc section" id="contacto">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-number">06</span>
      <h2 class="section-title">Contacto</h2>
    </div>

    <div class="cnc-intro reveal">
      <p class="cnc-intro-text">¿Interesado en colaborar? Estoy disponible para nuevos proyectos. Contáctame directamente, a través de mi representación, o descarga mi material profesional.</p>
    </div>

    <div class="cnc-panel reveal">
      <div class="cnc-grid">
        <!-- Contacto Directo -->
        <div class="cnc-card">
          <div class="cnc-card-accent">Directo</div>
          <h3 class="cnc-card-name">{personal.artistName}</h3>
          <div class="cnc-card-links">
            <a href={`mailto:${contact.direct.email}`} class="cnc-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <span>{contact.direct.email}</span>
            </a>
            <a href={`tel:${contact.direct.phone.replace(/\s/g, '')}`} class="cnc-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <span>{contact.direct.phone}</span>
            </a>
            <a href={contact.social[0].url} class="cnc-link" target="_blank" rel="noopener noreferrer">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              <span>Instagram</span>
            </a>
          </div>
        </div>

        <!-- Representación -->
        <div class="cnc-card">
          <div class="cnc-card-accent">Representación</div>
          <h3 class="cnc-card-name">{contact.manager.name}</h3>
          <div class="cnc-card-links">
            <a href={`mailto:${contact.manager.email}`} class="cnc-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <span>{contact.manager.email}</span>
            </a>
            <a href={`tel:${contact.manager.phone.replace(/\s/g, '')}`} class="cnc-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <span>{contact.manager.phone}</span>
            </a>
            <a href={contact.manager.agencyUrl} class="cnc-link" target="_blank" rel="noopener noreferrer">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              <span>Agencia Web</span>
            </a>
          </div>
        </div>

        <!-- Descargable ZIP -->
        <a href={downloads.photos.url} class="cnc-card cnc-card--download" target="_blank" rel="noopener noreferrer">
          <div class="cnc-card-accent">Descargable</div>
          <h3 class="cnc-card-name">{downloads.photos.label}</h3>
          <p class="cnc-dload-desc">{downloads.photos.description}</p>
          <span class="cnc-dload-cta">
            <span>Descargar ZIP</span>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          </span>
        </a>
      </div>

    </div>
  </div>
</section>

<!-- ===== GRADIENT DIVIDER ===== -->
<div class="section-divider" aria-hidden="true"></div>

<style>
  /* ==================================================================
     CONTACTO + DESCARGABLES + FICHA TÉCNICA
     Glass cards · editorial typography · theme-aware
     ================================================================== */  /* ===== CONTACTO + DESCARGABLES ===== */

  .cnc-intro {
    max-width: 640px;
    margin-bottom: var(--sp-2xl);
  }

  .cnc-intro-text {
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ===== UNIFIED GLASS PANEL ===== */
  .cnc-panel {
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    padding: var(--sp-2xl);
    transition: border-color 0.4s var(--ease);
  }

  .cnc-panel:hover {
    border-color: var(--glass-border-hover);
  }

  .cnc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--sp-lg);
  }

  /* ===== UNIFORM GLASS CARDS ===== */
  .cnc-card {
    display: flex;
    flex-direction: column;
    padding: var(--sp-lg) var(--sp-xl);
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.18);
    transition: all 0.4s var(--ease);
    position: relative;
    overflow: hidden;
  }

  [data-theme="dark"] .cnc-card {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.06);
  }

  .cnc-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.4s var(--ease);
    pointer-events: none;
  }

  .cnc-card:hover {
    transform: translateY(-6px);
    border-color: rgba(255, 255, 255, 0.35);
    box-shadow: 0 12px 40px var(--shadow-strong), inset 0 1px 0 rgba(255,255,255,0.2);
  }

  .cnc-card:hover::before {
    opacity: 1;
  }

  [data-theme="dark"] .cnc-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
    box-shadow: 0 12px 40px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.06);
  }

  /* Download card — behaves like an anchor, same glass look */
  .cnc-card--download {
    text-decoration: none;
    cursor: pointer;
  }

  .cnc-card--download:hover {
    box-shadow: 0 14px 48px var(--shadow-strong), inset 0 1px 0 rgba(255,255,255,0.25);
  }

  .cnc-card-accent {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--sp-sm);
    padding: 0.2rem 0.5rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    align-self: flex-start;
  }

  [data-theme="dark"] .cnc-card-accent {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.06);
  }

  .cnc-card-name {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--text);
    margin: 0 0 var(--sp-sm);
    letter-spacing: -0.02em;
  }

  .cnc-card-links {
    display: flex;
    flex-direction: column;
    gap: var(--sp-xs);
    margin-top: auto;
  }

  .cnc-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.35rem 0;
    transition: all 0.25s var(--ease);
    border-radius: var(--radius-xs);
  }

  .cnc-link:hover {
    color: var(--text);
    padding-left: 0.25rem;
  }

  .cnc-link svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    opacity: 0.4;
    transition: opacity 0.25s var(--ease), color 0.25s var(--ease);
  }

  .cnc-link:hover svg {
    opacity: 0.7;
  }

  .cnc-link span {
    border-bottom: 1px solid transparent;
    transition: border-color 0.25s var(--ease);
  }

  .cnc-link:hover span {
    border-color: var(--text);
  }

  /* ===== DOWNLOAD CARD ===== */
  .cnc-dload-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0 0 var(--sp-lg);
    flex: 1;
  }

  .cnc-dload-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text);
    padding: 0.45rem 0.9rem;
    border: 1.5px solid var(--text);
    transition: all 0.3s var(--ease);
    align-self: flex-start;
  }

  .cnc-dload-cta svg {
    width: 13px;
    height: 13px;
    transition: transform 0.3s var(--ease);
  }

  .cnc-card--download:hover .cnc-dload-cta {
    background: var(--text);
    color: var(--bg);
  }

  .cnc-card--download:hover .cnc-dload-cta svg {
    transform: translateX(3px);
  }

  /* ===== FICHA TÉCNICA ===== */
  .fch {
    position: relative;
  }

  .fch-layout {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--sp-2xl);
    align-items: start;
  }

  /* ---- Photo ---- */
  .fch-photo {
    position: sticky;
    top: 100px;
  }

  .fch-photo-frame {
    position: relative;
    border: 2px solid var(--text);
    overflow: hidden;
    transition: all 0.5s var(--ease);
  }

  .fch-photo-frame:hover {
    transform: scale(1.015);
  }

  .fch-photo-frame img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    display: block;
    transition: filter 0.7s var(--ease), transform 0.7s var(--ease);
  }

  .fch-photo-frame:hover img {
    filter: grayscale(100%) contrast(1.1);
    transform: scale(1.06);
  }

  .fch-photo-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding: 1rem;
    background: linear-gradient(transparent 40%, var(--text));
    transition: padding 0.4s var(--ease);
  }

  .fch-photo-frame:hover .fch-photo-overlay {
    padding-bottom: 1.5rem;
  }

  .fch-photo-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    opacity: 0.95;
  }

  .fch-photo-badge svg {
    width: 16px;
    height: 16px;
  }

  .fch-photo-stats {
    display: flex;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.7);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .fch-photo-stats span {
    padding: 0.2rem 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  /* ---- Data column ---- */
  .fch-data {
    display: flex;
    flex-direction: column;
    gap: var(--sp-lg);
  }

  /* ---- Glass cards ---- */
  .fch-card {
    padding: var(--sp-lg) var(--sp-xl);
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    transition: all 0.3s var(--ease);
  }

  .fch-card:hover {
    background: var(--glass-bg-hover);
    border-color: var(--glass-border-hover);
  }



  .fch-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--sp-lg);
    padding-bottom: var(--sp-sm);
    border-bottom: 1px solid var(--border);
  }

  .fch-card-tag {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text);
  }

  .fch-card-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    color: var(--text-muted);
    opacity: 0.7;
  }

  /* ---- Stats grid ---- */
  .fch-stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-md);
  }

  .fch-stat-item {
    padding: var(--sp-sm) 0;
    position: relative;
    transition: transform 0.3s var(--ease);
  }

  .fch-stat-item:hover {
    transform: translateX(4px);
  }

  .fch-stat-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    margin-bottom: var(--sp-sm);
    border: 1.5px solid var(--text);
    color: var(--text);
    transition: all 0.3s var(--ease);
  }

  .fch-stat-item:hover .fch-stat-icon {
    background: var(--text);
    color: var(--bg);
  }

  .fch-stat-icon svg {
    width: 16px;
    height: 16px;
  }

  .fch-stat-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    margin-bottom: 0.15rem;
  }

  .fch-stat-value {
    font-family: var(--font-heading);
    font-size: clamp(1.3rem, 2vw, 1.7rem);
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  /* ---- Row (half cards) ---- */
  .fch-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-lg);
  }

  .fch-card--half {
    padding: var(--sp-lg);
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
  }

  .fch-card--half:hover {
    background: var(--glass-bg-hover);
    border-color: var(--glass-border-hover);
  }

  /* ---- Meta list ---- */
  .fch-meta-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-sm);
  }

  .fch-meta-item {
    display: flex;
