---
import data from '../data/nicolas.json';
const { demoReel } = data;
---

<section class="reel section" id="demo-reel">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-number">03</span>
      <h2 class="section-title">Demo Reel</h2>
    </div>

    <!-- ===== REEL HERO ===== -->
    <div class="reel-hero reveal">
      <div class="reel-frame">
        <div class="reel-screen">
          <iframe
            src={demoReel.mainVideo}
            title={`Nicolás Capetillo - ${demoReel.mainTitle}`}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="no-referrer"
            allowfullscreen
          ></iframe>
        </div>

      </div>

      <div class="reel-credit">
        <span class="reel-credit-tag">2025</span>
        <h3 class="reel-credit-title">{demoReel.mainTitle}</h3>
      </div>
    </div>

    <!-- ===== DIVIDER ===== -->
    <hr class="reel-divider" aria-hidden="true" />

    <!-- ===== CLIPS ===== -->
    <div class="reel-clips">
      {demoReel.verticalVideos.map((video, i) => (
        <article class="reel-clip" style={`--i: ${i}`}>
          <div class="reel-clip-visual">
            <video controls playsinline preload="metadata" loading="lazy">
              <source src={video.src} type="video/mp4" />
            </video>
          </div>
          <div class="reel-clip-info">
            <span class="reel-clip-number">0{i + 1}</span>
            <div>
              <span class="reel-clip-source">Acting Lab</span>
              <p class="reel-clip-caption">{video.caption}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* ==================================================================
     DEMO REEL — Vertical Cinema
     Full-width hero · credit below · clip cards with air
     ================================================================== */



  /* ===== HERO ===== */
  .reel-hero {
    max-width: 960px;
    margin: 0 auto var(--sp-2xl);
  }

  .reel-frame {
    position: relative;
    border: 2px solid var(--text);
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    box-shadow: var(--glass-shadow);
    padding: clamp(0.75rem, 1.5vw, 1.5rem);
    transition: background 0.4s var(--ease), box-shadow 0.4s var(--ease);
  }

  .reel-frame:hover {
    background: var(--glass-bg-hover);
    box-shadow: 0 16px 56px var(--shadow-strong), inset 0 1px 0 rgba(255,255,255,0.15);
  }

  .reel-screen {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--near-black);
    border-radius: var(--radius-xs);
  }

  .reel-screen iframe {
    width: 100%;
    height: 100%;
    border: none;
  }



  /* ===== CREDIT ===== */
  .reel-credit {
    display: flex;
    align-items: baseline;
    gap: var(--sp-lg);
    margin-top: var(--sp-lg);
    margin-bottom: var(--sp-sm);
  }

  .reel-credit-tag {
    font-family: var(--font-mono);
    font-size: clamp(0.75rem, 1vw, 0.9rem);
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .reel-credit-title {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 4vw, 3rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: 0;
  }

  /* ===== DIVIDER ===== */
  .reel-divider {
    border: none;
    height: 2px;
    background: var(--border);
    max-width: 960px;
    margin: var(--sp-2xl) auto;
  }

  /* ===== CLIPS ===== */
  .reel-clips {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2xl);
  }

  .reel-clip {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: var(--sp-xl);
    align-items: center;
    padding: var(--sp-lg) var(--sp-xl);
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    transition: background 0.4s var(--ease), border-color 0.4s var(--ease), box-shadow 0.4s var(--ease);
    animation: clipIn 0.7s var(--ease) both;
    animation-delay: calc(var(--i, 0) * 0.15s + 0.3s);
  }

  .reel-clip:hover {
    background: var(--glass-bg-hover);
    border-color: var(--glass-border-hover);
    box-shadow: 0 12px 40px var(--shadow-strong), inset 0 1px 0 rgba(255,255,255,0.1);
  }

  @keyframes clipIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .reel-clip-visual {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 16;
    max-height: 480px;
    overflow: hidden;
    border-radius: var(--radius-xs);
    background: var(--near-black);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.06);
  }

  .reel-clip-visual video {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: var(--near-black);
  }

  .reel-clip-info {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-lg);
  }

  .reel-clip-number {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 0.85;
    color: var(--text);
    opacity: 0.1;
    letter-spacing: -0.04em;
    user-select: none;
    flex-shrink: 0;
  }

  .reel-clip-source {
    display: block;
    font-family: var(--font-mono);
    font-size: clamp(0.65rem, 0.8vw, 0.75rem);
    font-weight: 600;
    letter-spacing: 0.5px;
    color: var(--text-muted);
    margin-bottom: 0.2rem;
  }

  .reel-clip-caption {
    font-family: var(--font-mono);
    font-size: clamp(0.85rem, 1.2vw, 1.05rem);
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text);
    margin: 0;
    line-height: 1.4;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .reel-clip {
      grid-template-columns: 140px 1fr;
      gap: var(--sp-lg);
    }

    .reel-clip-number {
      display: none;
    }

    .reel-credit {
      flex-direction: column;
      gap: var(--sp-sm);
    }
  }

  @media (max-width: 480px) {
    .reel-clip {
      grid-template-columns: 1fr;
      gap: var(--sp-md);
    }

    .reel-clip-visual {
      max-width: 280px;
      margin: 0 auto;
    }

    .reel-clip-info {
      gap: var(--sp-sm);
    }
  }

  @media (hover: none) and (pointer: coarse) {
    .reel-clip:hover {
      background: var(--glass-bg);
      border-color: var(--glass-border);
      box-shadow: var(--glass-shadow);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reel-clip { animation: none; }
    .reel-frame { transition: none; }
    .reel-clip-visual { transition: none; }
  }
</style>
