---
import data from '../data/nicolas.json';
const { filmography } = data;
---

<section class="films section" id="filmografia">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-number">02</span>
      <h2 class="section-title">Filmografía</h2>
    </div>
  </div>

  <div class="films-stage">
    {filmography.map((film, i) => (
      <article
        class="film"
        style={`--i: ${i}`}
        onclick={film.imdbUrl || film.videoUrl ? `if(!event.target.closest('.film-btn')){window.open('${film.imdbUrl || film.videoUrl}','_blank')}` : undefined}
        role="button"
        tabindex={film.imdbUrl || film.videoUrl ? 0 : undefined}
        onkeydown={film.imdbUrl || film.videoUrl ? `if(event.key==='Enter'||event.key===' '){event.preventDefault();window.open('${film.imdbUrl || film.videoUrl}','_blank')}` : undefined}
        aria-label={film.imdbUrl || film.videoUrl ? `Ver ${film.title} en ${film.imdbUrl ? 'IMDb' : 'YouTube'}` : undefined}
      >
        <!-- Backdrop image (slow zoom) -->
        <div class="film-bg" aria-hidden="true">
          <img src={film.photo} alt="" loading="lazy" />
        </div>
        <!-- Dark overlay for readability -->
        <div class="film-overlay" aria-hidden="true"></div>

        <!-- Content shell -->
        <div class="film-shell container">
          <div class="film-layout">
            <!-- Left: year number (graphic) -->
            <div class="film-year-col" aria-hidden="true">
              <span class="film-year-num">{film.year}</span>
            </div>

            <!-- Center: main content -->
            <div class="film-main">
              <div class="film-header">
                <span class="film-tag">
                  {film.status === 'released' && 'Estrenado'}
                  {film.status === 'post-production' && 'Post-Producción'}
                  {film.status === 'active' && 'Activo'}
                </span>
                <span class="film-platform">{film.platform}</span>
              </div>

              <h3 class="film-title">{film.title}</h3>
              <p class="film-role">{film.role}</p>

              <p class="film-desc">{film.description}</p>

              {film.episodes && (
                <span class="film-episodes">{film.episodes}</span>
              )}

              <div class="film-actions">
                {film.status === 'released' && film.rating && (
                  <span class="film-rating">⭐ {film.rating}</span>
                )}
                {(film.imdbUrl || film.videoUrl) && (
                  <a
                    href={film.imdbUrl || film.videoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="film-btn"
                  >
                    {film.imdbUrl ? 'IMDb' : 'YouTube'}
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>

        <!-- Divider between films -->
        {i < filmography.length - 1 && <div class="film-divider" aria-hidden="true"></div>}
      </article>
    ))}
  </div>
</section>



<style>
  /* ==================================================================
     FILMOGRAPHY — Dark Cinema Strips
     Always dark · per-film accent hover · mobile tappable
     ================================================================== */

  .films {
    background: #050505;
    background-image:
      radial-gradient(ellipse 60% 40% at 20% 30%, rgba(255,255,255,0.03) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 80% 70%, rgba(255,255,255,0.02) 0%, transparent 60%);
    padding-bottom: var(--sp-3xl);
  }

  /* Section header overrides for dark bg */
  .films .section-header {
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }

  .films .section-number {
    color: #fff;
    opacity: 0.08;
  }

  .films .section-title {
    color: #fff;
  }

  /* Override container spacing */
  .films .container:first-child {
    padding-bottom: var(--sp-2xl);
  }

  .films-stage {
    display: flex;
    flex-direction: column;
  }

  /* ===== INDIVIDUAL FILM ROW ===== */
  .film {
    position: relative;
    min-height: clamp(400px, 48vh, 500px);
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #0a0a0a;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    cursor: pointer;
    animation: filmIn 0.8s var(--ease) both;
    animation-delay: calc(var(--i, 0) * 0.2s);
    transition: background 0.5s var(--ease);
    outline: none;
  }

  @keyframes filmIn {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .film:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.4);
    outline-offset: -2px;
  }

  .film:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* ===== BACKDROP IMAGE (slow zoom) ===== */
  .film-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .film-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    opacity: 0.1;
    filter: grayscale(1) contrast(1.2);
    transition: opacity 0.8s var(--ease), filter 0.8s var(--ease);
    animation: slowZoom 20s ease-in-out infinite;
  }

  @keyframes slowZoom {
    0%, 100% { transform: scale(1.08); }
    50% { transform: scale(1.2); }
  }

  .film:hover .film-bg img,
  .film:focus-visible .film-bg img,
  .film:active .film-bg img {
    opacity: 0.55;
    filter: grayscale(0) contrast(1.05);
  }

  /* El Centauro del Norte — imagen más clara (la toma es oscura) */
  .film[style*="--i: 0"] .film-bg img {
    opacity: 0.3;
    filter: grayscale(0.5) brightness(1.6) contrast(0.95);
  }

  .film[style*="--i: 0"]:hover .film-bg img {
    opacity: 0.7;
    filter: grayscale(0) brightness(1.4) contrast(1.0);
  }

  /* ===== DARK OVERLAY (readability) ===== */
  .film-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.75) 0%,
      rgba(0, 0, 0, 0.45) 50%,
      rgba(0, 0, 0, 0.7) 100%
    );
    pointer-events: none;
    transition: opacity 0.6s var(--ease);
  }

  .film:hover .film-overlay {
    opacity: 0.5;
  }

  /* ===== SHELL ===== */
  .film-shell {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  .film-layout {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: var(--sp-2xl);
    align-items: start;
    padding: var(--sp-2xl) 0;
  }

  /* ===== YEAR GRAPHIC ===== */
  .film-year-col {
    display: flex;
    justify-content: flex-end;
    padding-top: 0.15rem;
  }

  .film-year-num {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 0.85;
    color: #fff;
    opacity: 0.1;
    letter-spacing: -0.06em;
    transition: opacity 0.5s var(--ease);
    user-select: none;
  }

  .film:hover .film-year-num {
    opacity: 0.2;
  }

  /* ===== MAIN CONTENT ===== */
  .film-main {
    max-width: 720px;
    color: #fff;
  }

  .film-header {
    display: flex;
    align-items: center;
    gap: var(--sp-md);
    margin-bottom: var(--sp-sm);
  }

  .film-tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #0a0a0a;
    background: rgba(255, 255, 255, 0.9);
    line-height: 1.3;
  }

  .film-platform {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }

  .film-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0 0 0.25rem;
    text-wrap: balance;
  }

  .film-role {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: var(--sp-lg);
  }

  .film-desc {
    font-size: clamp(0.95rem, 1.1vw, 1.05rem);
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.8);
    max-width: 600px;
    margin-bottom: var(--sp-md);
  }

  .film-episodes {
    display: inline-block;
    padding: 0.2rem 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    color: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.2);
    margin-bottom: var(--sp-md);
  }

  /* ===== ACTIONS ===== */
  .film-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-md);
    margin-top: var(--sp-lg);
  }

  .film-rating {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    color: rgba(255, 255, 255, 0.7);
    padding: 0.3rem 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .film-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.65rem 1.4rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    color: #0a0a0a;
    background: rgba(255, 255, 255, 0.9);
    border: 2px solid rgba(255, 255, 255, 0.9);
    transition: all 0.3s var(--ease);
    pointer-events: auto;
  }

  .film-btn:hover {
    background: transparent;
    color: rgba(255, 255, 255, 0.9);
  }

  .film-btn svg {
    width: 14px;
    height: 14px;
    transition: transform 0.3s var(--ease);
  }

  .film-btn:hover svg {
    transform: translateX(3px);
  }

  /* ===== DIVIDER ===== */
  .film-divider {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.06);
    z-index: 3;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .film-layout {
      gap: var(--sp-lg);
    }

    .film-year-col {
      width: 60px;
    }

    .film-year-num {
      font-size: clamp(1.8rem, 3vw, 2.5rem);
    }
  }

  @media (max-width: 768px) {
    .film {
      min-height: auto;
    }

    .film-bg img {
      opacity: 0.35;
      filter: grayscale(0) contrast(1.05);
    }

    .film[style*="--i: 0"] .film-bg img {
      opacity: 0.55;
      filter: grayscale(0) brightness(1.4) contrast(1.0);
    }

    .film[style*="--i: 0"] .film-bg img {
      object-position: 82% 30%;
    }

    .film[style*="--i: 2"] .film-bg img {
      object-position: 70% 30%;
    }

    .film-overlay {
      opacity: 0.6;
    }

    .film-layout {
      grid-template-columns: 1fr;
      gap: var(--sp-sm);
      padding: var(--sp-xl) 0;
    }

    .film-year-col {
      display: none;
    }

    .film-title {
      font-size: clamp(1.6rem, 7vw, 2.2rem);
    }

    .film-header {
      flex-wrap: wrap;
      gap: var(--sp-sm);
    }

    .film-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .film-btn {
      width: 100%;
      justify-content: center;
      padding: 0.8rem;
      font-size: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .film-layout {
      padding: var(--sp-lg) 0;
    }

    .film-tag {
      font-size: 0.6rem;
    }

    .film-platform {
      font-size: 0.65rem;
    }

    .film-role {
      font-size: 0.75rem;
    }

    .film-desc {
      font-size: 0.9rem;
    }
  }

  /* Touch devices — suppress hover, use active state */
  @media (hover: none) and (pointer: coarse) {
    .film:hover .film-bg img {
      opacity: 0.1;
      filter: grayscale(1) contrast(1.2);
    }

    .film:active .film-bg img {
      opacity: 0.35;
      filter: grayscale(0) contrast(1.05);
    }

    .film:hover .film-overlay {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .film { animation: none; }

    .film-bg img { animation: none; transition: none; }
    .film-btn svg { transition: none; }
    .film-btn:hover svg { transform: none; }
    .film-overlay { transition: none; }
  }
</style>
